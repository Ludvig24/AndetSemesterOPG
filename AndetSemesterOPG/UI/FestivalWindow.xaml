<Window x:Class="AndetSemesterOPG.UI.FestivalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AndetSemesterOPG.UI"
        mc:Ignorable="d"
        Title="FestivalWindow" Height="450" Width="800">
    <Grid>
        <Label x:Name="IndgangØstLabel"  Content="Indgang Øst" HorizontalAlignment="Left" Margin="620,326,0,0" VerticalAlignment="Top" Height="26" Width="91"/>
