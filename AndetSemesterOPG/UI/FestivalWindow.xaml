        <Label Content="Antal festivaldeltagere" HorizontalAlignment="Left" Margin="494,243,0,0" VerticalAlignment="Top"/>
        <Label Content="Antal festivaldeltagere" HorizontalAlignment="Left" Margin="494,348,0,0" VerticalAlignment="Top"/>
        <Button Content="Tilbage" HorizontalAlignment="Left" VerticalAlignment="Top" Height="36" Width="63" x:Name="backButtonFestivalWindow" Click="backButtonFestivalWindow_Click"/>
        <Label Content="Camp A" HorizontalAlignment="Left" Margin="150,88,0,0" VerticalAlignment="Top"/>
        <Label Content="Camp B" HorizontalAlignment="Left" Margin="150,248,0,0" VerticalAlignment="Top"/>
        <Label Content="Antal festivaldeltagere" HorizontalAlignment="Left" Margin="25,116,0,0" VerticalAlignment="Top"/>
        <Label Content="Antal festivaldeltagere" HorizontalAlignment="Left" Margin="25,276,0,0" VerticalAlignment="Top"/>
        <Label x:Name="TotalAttendeeCampA" Content="Antal" HorizontalAlignment="Left" Margin="170,116,0,0" VerticalAlignment="Top"/>
        <Label x:Name="TotalAttendeeCampB" Content="Antal" HorizontalAlignment="Left" Margin="160,276,0,0" VerticalAlignment="Top"/>
        <Label Content="/" HorizontalAlignment="Left" Margin="210,116,0,0" VerticalAlignment="Top"/>
        <Label x:Name="CampACapacity" Content="Capacity" HorizontalAlignment="Left" Margin="240,116,0,0" VerticalAlignment="Top"/>
        <Label Content="/" HorizontalAlignment="Left" Margin="210,276,0,0" VerticalAlignment="Top"/>
        <Label x:Name="CampBCapacity" Content="Capacity" HorizontalAlignment="Left" Margin="240,276,0,0" VerticalAlignment="Top"/>
        <Button x:Name="LockCampAButton" Content="Lås Camp A" HorizontalAlignment="Left" Height="35" Margin="45,158,0,0" VerticalAlignment="Top" Width="125" Click="LockCampAButton_Click"/>
        <Button x:Name="OpenCampAButton" Content="Åben Camp A" HorizontalAlignment="Left" Margin="193,158,0,0" VerticalAlignment="Top" Height="35" Width="125" Click="OpenCampAButton_Click"/>
        <Button x:Name="LockCampBButton" Content="Lås Camp B" HorizontalAlignment="Left" Height="35" Margin="45,312,0,0" VerticalAlignment="Top" Width="125" Click="LockCampBButton_Click"/>
        <Button x:Name="OpenCampBButton" Content="Åben Camp B" HorizontalAlignment="Left" Margin="193,312,0,0" VerticalAlignment="Top" Height="35" Width="125" Click="OpenCampBButton_Click"/>
        <Button x:Name="SubscribeToCamps" Content="Tilmeld notifikationer" HorizontalAlignment="Left" VerticalAlignment="Top" Height="37" Width="120" Click="SubscribeToCamps_Click" Margin="408,8,0,0"/>
        <Button x:Name="UnsubscribeFromCamps" Content="Afmeld notifikationer" HorizontalAlignment="Left" VerticalAlignment="Top" Height="37" Width="120" Margin="282,8,0,0" Click="UnsubscribeFromCamps_Click"/>
        <Button x:Name="AttendeeSimulationButton" Content="Attendee Simulation" HorizontalAlignment="Left" Margin="685,-2,0,0" VerticalAlignment="Top" Height="43" Width="114" Click="AttendeeSimulationButton_Click"/>
        <Label x:Name="SubscribtionstatusLabel" Content="Du er nu tilmeldt notifikationer om camp status" HorizontalAlignment="Center" Margin="0,55,0,0" VerticalAlignment="Top"/>
        <Label x:Name="CampA_StatusLabel" Content="Camp A er åben" HorizontalAlignment="Left" Margin="120,0,0,0" VerticalAlignment="Center"/>
        <Label x:Name="CampB_StatusLabel" Content="Camp B er åben" HorizontalAlignment="Left" Margin="120,364,0,0" VerticalAlignment="Top"/>
        <Rectangle HorizontalAlignment="Left" Height="150" Margin="25,88,0,0" Stroke="Black" VerticalAlignment="Top" Width="317"/>
        <Rectangle HorizontalAlignment="Left" Height="150" Margin="25,253,0,0" Stroke="Black" VerticalAlignment="Top" Width="317"/>
        <Rectangle HorizontalAlignment="Left" Height="75" Margin="494,218,0,0" Stroke="Black" VerticalAlignment="Top" Width="284"/>
        <Rectangle HorizontalAlignment="Left" Height="75" Margin="494,327,0,0" Stroke="Black" VerticalAlignment="Top" Width="284"/>
