<Window x:Class="AndetSemesterOPG.UI.AttendeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AndetSemesterOPG.UI"
        mc:Ignorable="d"
        Title="AttendeeWindow" Height="450" Width="800">
    <Grid Margin="400,146,0,0">
        <Button Content="Tilbage" x:Name="AttendeeBackButton" HorizontalAlignment="Left" Margin="-400,-147,0,0" VerticalAlignment="Top" Height="36" Width="63" Click="AttendeeBackButton_Click"/>
        <DataGrid x:Name="AttendeesList" AutoGenerateColumns="False"  Margin="-208,-101,149,63" CanUserSortColumns="False" >
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="IsHitTestVisible" Value="False"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding AttendeeID}"></DataGridTextColumn>
                <DataGridTextColumn Header="Fornavn" Binding="{Binding AttendeeFirstName}"></DataGridTextColumn>
                <DataGridTextColumn Header="Efternavn" Binding="{Binding AttendeeLastName}"></DataGridTextColumn>
                <DataGridTextColumn Header="Camp Navn" Binding="{Binding CampName}"></DataGridTextColumn>
                <DataGridTextColumn Header="Indgang" Binding="{Binding EntranceId}"></DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>
        <Label Content="Antal festivaldeltager:"  HorizontalAlignment="Left" Height="29" Margin="-382,154,0,0" VerticalAlignment="Top" Width="125"/>
        <Label x:Name="totalAttendees" Content="Total label" HorizontalAlignment="Left" Margin="-356,181,0,0" VerticalAlignment="Top" Width="68"/>
        <Button x:Name="refreshButton"  Content="Opdater" HorizontalAlignment="Left" Margin="-345,-68,0,0" VerticalAlignment="Top" Height="26" Width="110" Click="refreshButton_Click"/>
        <Button x:Name="sortNamesButton" Content="Sorter: Fornavn" HorizontalAlignment="Left" Margin="-345,-28,0,0" VerticalAlignment="Top" Height="26" Width="110" Click="sortNamesButton_Click"/>
        <Button x:Name="sortByEntranceIdButton" Content="Sorter: Indgang" HorizontalAlignment="Left" Margin="-345,15,0,0" VerticalAlignment="Top" Height="26" Width="110" Click="sortByEntranceIdButton_Click"/>
        <Button x:Name="sortByCampNameButton" Content="Sorter: Camp Navn" HorizontalAlignment="Left" Margin="-345,62,0,0" VerticalAlignment="Top" Height="26" Width="110" Click="sortByCampNameButton_Click"/>
        <Button x:Name="AdminResetButton" Content="Admin Reset" HorizontalAlignment="Left" Margin="281,-68,0,0" VerticalAlignment="Top" Height="26" Width="93" Click="AdminResetButton_Click"/>

    </Grid>
</Window>
