<Window x:Class="AndetSemesterOPG.UI.AttendeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AndetSemesterOPG.UI"
        mc:Ignorable="d"
        Title="AttendeeWindow" Height="450" Width="800">
    <Grid Margin="400,146,0,0">
		<Button Content="Tilbage" x:Name="AttendeeBackButton" HorizontalAlignment="Left" Margin="-399,-146,0,0" VerticalAlignment="Top" Height="29" Width="60" Click="AttendeeBackButton_Click"/>
		<DataGrid x:Name="AttendeesList" AutoGenerateColumns="False"  Margin="-208,-101,149,63" >
			<DataGrid.Columns>
				<DataGridTextColumn Header="Id" Binding="{Binding AttendeeID}"></DataGridTextColumn>
				<DataGridTextColumn Header="Fornavn" Binding="{Binding AttendeeFirstName}"></DataGridTextColumn>
				<DataGridTextColumn Header="Efternavn" Binding="{Binding AttendeeLastName}"></DataGridTextColumn>
				<DataGridTextColumn Header="Camp Navn" Binding="{Binding CampName}"></DataGridTextColumn>
				<DataGridTextColumn Header="Indgang" Binding="{Binding EntranceId}"></DataGridTextColumn>

			</DataGrid.Columns>
		</DataGrid>
		<Label Content="Total antal" HorizontalAlignment="Left" Height="29" Margin="-371,92,0,0" VerticalAlignment="Top" Width="82"/>
		<Label x:Name="totalAttendees" Content="" HorizontalAlignment="Left" Margin="-298,92,0,0" VerticalAlignment="Top" Width="68"/>
        <Button x:Name="refreshButton"  Content="Opdater" HorizontalAlignment="Left" Margin="-328,-48,0,0" VerticalAlignment="Top" Height="26" Width="60" Click="refreshButton_Click"/>
		<Button x:Name="sortNamesButton" Content="Sorter: Fornavn" HorizontalAlignment="Left" Margin="-330,15,0,0" VerticalAlignment="Top" Click="sortNamesButton_Click"/>
        <Button x:Name="sortByEntranceIdButton" Content="Sorter: Indgang" HorizontalAlignment="Left" Margin="-328,160,0,0" VerticalAlignment="Top" Click="sortByEntranceIdButton_Click"/>
        <Button x:Name="sortByCampNameButton" Content="Sorter: Camp Navn" HorizontalAlignment="Left" Margin="-372,205,0,0" VerticalAlignment="Top" Click="sortByCampNameButton_Click"/>
        <Button x:Name="AdminResetButton" Content="Admin Reset" HorizontalAlignment="Left" Margin="270,-63,0,0" VerticalAlignment="Top" Height="41" Width="98" Click="AdminResetButton_Click"/>

    </Grid>
</Window>
