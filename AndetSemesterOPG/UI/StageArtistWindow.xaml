<Window x:Class="AndetSemesterOPG.UI.StageArtistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AndetSemesterOPG.UI"
        mc:Ignorable="d"
        Title="StageArtistWindow" Height="450" Width="800">
    
    <Grid>
        <Grid x:Name="Schedule_Arena"  HorizontalAlignment="Left" Height="240" Margin="450,170,0,0" VerticalAlignment="Top" Width="310" ShowGridLines="True">
            <Rectangle StrokeThickness="1" Stroke= "Black" Grid.ColumnSpan="5" Grid.RowSpan="4" />
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
        </Grid>
        <Grid x:Name="Schedule_Orange"  HorizontalAlignment="Left" Height="240" Margin="52,170,0,0" VerticalAlignment="Top" Width="320" ShowGridLines="True">
            <Rectangle StrokeThickness="1" Stroke= "Black" Grid.ColumnSpan="5" Grid.RowSpan="4" />
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
        </Grid>
        <Button x:Name="BackButtoninStage" Content="Tilbage" HorizontalAlignment="Left" Height="41" VerticalAlignment="Top" Width="111"/>
        <Button x:Name="AddArtistButton" Content="Tilføj" HorizontalAlignment="Left" Height="43" Margin="373,118,0,0" VerticalAlignment="Top" Width="104"/>
        <ComboBox x:Name="ArtistTimeCombobox" HorizontalAlignment="Left" Height="34" Margin="379,79,0,0" VerticalAlignment="Top" Width="92" Text="Tid">
            <ComboBoxItem Content="16:00"></ComboBoxItem>
            <ComboBoxItem Content="18:00"></ComboBoxItem>
            <ComboBoxItem Content="20:00"></ComboBoxItem>
            <ComboBoxItem Content="22:00"></ComboBoxItem>
        </ComboBox>
        <ComboBox x:Name="ArtistDateCombobox" HorizontalAlignment="Left" Height="30" Margin="373,44,0,0" VerticalAlignment="Top" Width="110" Text="Dato">
            <ComboBoxItem Content="Onsdag"></ComboBoxItem>
            <ComboBoxItem Content="Torsdag"></ComboBoxItem>
            <ComboBoxItem Content="Fredag"></ComboBoxItem>
            <ComboBoxItem Content="Lørdag"></ComboBoxItem>
            <ComboBoxItem Content="Søndag"></ComboBoxItem>
        </ComboBox>
        <TextBox x:Name="ArtistNameTextBox" HorizontalAlignment="Left" Margin="92,56,0,0" TextWrapping="Wrap" Text="Kunsters navn" VerticalAlignment="Top" Width="120"/>
        <ComboBox x:Name="StageNameComboBox" HorizontalAlignment="Left" Margin="244,127,0,0" VerticalAlignment="Top" Width="120" Text="Vælg scene">
            <ComboBoxItem Content="Orange Scene"></ComboBoxItem>
            <ComboBoxItem Content="Arena Scene"></ComboBoxItem>
        </ComboBox>




    </Grid>
</Window>
